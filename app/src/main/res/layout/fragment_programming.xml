<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Question Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_editor"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/textQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextPrimary"
                android:textSize="17sp"
                android:fontFamily="@font/rubik"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Code Input Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Код программы"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:fontFamily="@font/nunitosans"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_code_editor"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/inputCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="print('Hello, World!')"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:minLines="8"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="#60FFFFFF"
                android:background="@android:color/transparent"
                android:fontFamily="@font/sourcecodepro"
                android:textSize="14sp"
                android:padding="16dp" />
        </LinearLayout>

        <!-- Stdin Input Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Входные данные (stdin)"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:fontFamily="@font/nunitosans"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/inputStdin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите тестовые данные..."
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:minLines="3"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="#60FFFFFF"
                android:background="@android:color/transparent"
                android:fontFamily="@font/sourcecodepro"
                android:textSize="14sp"
                android:padding="16dp" />
        </LinearLayout>

        <!-- Test Result Output -->
        <TextView
            android:id="@+id/textTestLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Результат теста"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:fontFamily="@font/nunitosans"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:fontFamily="@font/sourcecodepro"
            android:background="@drawable/bg_result_success"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            android:lineSpacingExtra="4dp" />

        <!-- Expected Output Hint (if available) -->
        <TextView
            android:id="@+id/textExpectedOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/sourcecodepro"
            android:background="@drawable/bg_input_field"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            android:lineSpacingExtra="4dp" />

        <!-- Test Button -->
        <Button
            android:id="@+id/btnRun"
            style="@style/CodemyButton.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Тест"
            android:stateListAnimator="@null"
            android:gravity="center" />

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmit"
            style="@style/CodemyButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Отправить"
            android:stateListAnimator="@null"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <!-- Next Step Button (hidden by default) -->
        <Button
            android:id="@+id/btnNext"
            style="@style/CodemyButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Перейти на следующий шаг"
            android:stateListAnimator="@null"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <!-- Retry Button (hidden by default) -->
        <Button
            android:id="@+id/btnRetry"
            style="@style/CodemyButton.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Попробовать снова"
            android:stateListAnimator="@null"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <!-- Hidden WebView for Python execution -->
        <WebView
            android:id="@+id/webViewPyodide"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
