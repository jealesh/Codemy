<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_above="@id/bottomNav"
        android:layout_alignParentTop="true"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Профиль карточка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card_transparent"
                android:padding="24dp"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <!-- Аватар -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_avatar_border_transparent" />

                    <ImageView
                        android:id="@+id/profileAvatar"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:scaleType="centerCrop" />
                </FrameLayout>

                <!-- Имя пользователя -->
                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Имя Пользователя"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/nunitosans"
                    android:textColor="@color/colorTextPrimary" />

                <!-- Логин -->
                <TextView
                    android:id="@+id/profileLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="username"
                    android:textSize="14sp"
                    android:fontFamily="@font/rubik"
                    android:textColor="@color/colorAccent"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Статистика - растянуты равномерно -->
            <LinearLayout
                android:id="@+id/statsBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_transparent"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:minHeight="120dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="28sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/profileStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 дней"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunitosans"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Стрик"
                        android:textSize="12sp"
                        android:fontFamily="@font/rubik"
                        android:textColor="#80FFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_transparent"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:minHeight="120dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="28sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/profileXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunitosans"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Опыт"
                        android:textSize="12sp"
                        android:fontFamily="@font/rubik"
                        android:textColor="#80FFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_transparent"
                    android:padding="16dp"
                    android:gravity="center"
                    android:minHeight="120dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆"
                        android:textSize="28sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/profileMaxStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunitosans"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Рекорд"
                        android:textSize="12sp"
                        android:fontFamily="@font/rubik"
                        android:textColor="#80FFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Достижения -->
            <TextView
                android:id="@+id/profileAchievementTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏅 Достижения"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/nunitosans"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/certificatesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_lesson_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пока нет достижений"
                    android:textSize="14sp"
                    android:fontFamily="@font/rubik"
                    android:textColor="#80FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Проходите уроки и получайте награды!"
                    android:textSize="12sp"
                    android:fontFamily="@font/rubik"
                    android:textColor="#60FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Кнопка: Выйти -->
            <Button
                android:id="@+id/btnLogout"
                style="@style/CodemyButton.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:text="🚪 Выйти из аккаунта"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

    <!-- Нижнее меню -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/include_bottom_navigation" />

</RelativeLayout>
