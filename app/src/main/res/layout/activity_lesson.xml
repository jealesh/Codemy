<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Заголовок -->
    <LinearLayout
        android:id="@+id/headerPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvLessonTitle"
            android:layout_width="wrap_content"
            android:background="@drawable/bg_text_transparent"
            android:layout_height="wrap_content"
            android:text="Урок"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunitosans"
            android:textColor="@color/colorTextPrimary" />

        <!-- Прогресс урока -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_text_transparent"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvLessonProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_text_transparent"
                android:layout_weight="1"
                android:text="0%"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/rubik"
                android:textColor="@color/colorTextPrimary"
                android:gravity="start" />

            <ProgressBar
                android:id="@+id/progressLesson"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:background="@drawable/bg_text_transparent"
                android:layout_height="8dp"
                android:layout_weight="3"
                android:progressDrawable="@drawable/bg_progress_horizontal"
                android:max="100"
                android:progress="0" />
        </LinearLayout>
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/colorAccent"
        app:tabSelectedTextColor="@color/colorTextPrimary"
        app:tabTextColor="#80FFFFFF"
        app:tabIndicatorHeight="4dp"
        app:tabBackground="@android:color/transparent"
        android:layout_marginBottom="8dp" />

</LinearLayout>
