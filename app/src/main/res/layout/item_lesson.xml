<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_lesson_card"
    android:padding="20dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <!-- Иконка урока -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_text_transparent"
        android:gravity="center"
        android:layout_marginEnd="16dp">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_text_transparent"
            android:src="@drawable/ic_code_browser"
            android:contentDescription="@string/lesson_icon_content_description" />
    </LinearLayout>

    <!-- Информация об уроке -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/bg_text_transparent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textLessonTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_text_transparent"
            android:text="Ввод и вывод данных"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunitosans"
            android:textColor="@color/colorTextPrimary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_text_transparent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Круговой индикатор прогресса -->
            <ProgressBar
                android:id="@+id/progressLessonCircle"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_text_transparent"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_circle_lesson" />

            <!-- Процент выполнения -->
            <TextView
                android:id="@+id/textLessonProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:background="@drawable/bg_text_transparent"
                android:textSize="13sp"
                android:fontFamily="@font/rubik"
                android:textColor="@color/colorAccent"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Индикатор завершения (галочка для 100%) -->
    <LinearLayout
        android:id="@+id/completionBadge"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_success_circle"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="20sp"
            android:textColor="@color/colorBackground"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
