<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Заголовок -->
    <LinearLayout
        android:id="@+id/headerPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/textLeagueName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Еженедельный рейтинг"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunitosans"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:id="@+id/textDaysLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 дня до завершения недели"
            android:textSize="14sp"
            android:fontFamily="@font/rubik"
            android:textColor="@color/colorAccent"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Список участников -->
    <ListView
        android:id="@+id/leagueListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/headerPanel"
        android:layout_above="@id/bottomNav"
        android:divider="@null"
        android:dividerHeight="8dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp" />

    <!-- Нижняя навигация -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/include_bottom_navigation" />

</RelativeLayout>
