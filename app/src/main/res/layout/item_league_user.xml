<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_league_item"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <!-- Ранг -->
    <LinearLayout
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_rank_badge"
        android:gravity="center"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/userRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunitosans"
            android:textColor="@color/colorBackground" />
    </LinearLayout>

    <!-- Аватар -->
    <ImageView
        android:id="@+id/userAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_avatar_placeholder"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_avatar_circle" />

    <!-- Информация -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/userName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Имя пользователя"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/nunitosans"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:id="@+id/userXPWeekly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1500 XP за 7 дней"
            android:textSize="14sp"
            android:fontFamily="@font/rubik"
            android:textColor="@color/colorAccent"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Медаль для топ-3 -->
    <TextView
        android:id="@+id/userMedal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:visibility="gone" />

</LinearLayout>
